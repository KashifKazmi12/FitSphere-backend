# Copy to .env and adjust. Values here match defaults used in code when unset.

# --- Server ---
PORT=5001
# Browser origin for CORS, email links, and Stripe Checkout return URLs (no trailing slash)
CLIENT_ORIGIN=http://localhost:5173

# --- Database ---
MONGODB_URI=mongodb://127.0.0.1:27017/fitsphere

# --- Auth (JWT) ---
JWT_ACCESS_SECRET=change-me-access
# Reserved if you add refresh tokens later
JWT_REFRESH_SECRET=change-me-refresh

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5001/auth/google/callback

# --- Stripe (optional; required for POST /subscribe and /webhooks/stripe) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Checkout subscription price (required for POST /subscribe)
STRIPE_PRICE_PREMIUM=
# Reserved for future tiers / UI (not read by server code yet)
STRIPE_PRICE_FREE=

# --- Catalog APIs ---
# Exercise search uses wger (public API; no key). Override base URL if needed.
# WGER_API_URL=https://wger.de/api/v2
# Food search uses Open Food Facts (no API key; not configurable via env).

# --- OpenAI (optional; if OPENAI_API_KEY is empty, workout plans use built-in rules) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Email (optional — nodemailer + SMTP)
# If SMTP_* is incomplete, notification preference toggles still save but no email is sent.
# Gmail: App Password, port 587, SMTP_SECURE=false (STARTTLS).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# From address (defaults to SMTP_USER if empty)
EMAIL_FROM=
EMAIL_FROM_NAME=FitSphere
EMAIL_BRAND_ACCENT=#0066ee

# --- Scheduled reminder emails (node-cron)
# Set to false to disable all digest jobs (workout reminder, challenge digest, weekly summary).
REMINDER_CRONS_ENABLED=
# IANA timezone for cron expressions below (optional; server local time if unset)
REMINDER_CRON_TIMEZONE=
# Standard 5-field cron (minute hour day month weekday). Defaults shown:
CRON_WORKOUT_REMINDER=0 9 * * *
CRON_CHALLENGE_DIGEST=0 10 * * 1
CRON_WEEKLY_SUMMARY=0 18 * * 0
