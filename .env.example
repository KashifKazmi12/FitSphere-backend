# --- Server ---
PORT=5001
# Browser origin for CORS and Stripe Checkout return URLs (no trailing slash)
CLIENT_ORIGIN=http://localhost:5173

# --- Database ---
MONGODB_URI=mongodb://127.0.0.1:27017/fitsphere

# --- Auth (JWT) ---
JWT_ACCESS_SECRET=change-me-access
# Reserved if you add refresh tokens later
JWT_REFRESH_SECRET=change-me-refresh

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5001/auth/google/callback

# --- Stripe (optional; required for POST /subscribe and /webhooks/stripe) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from Stripe Dashboard (Checkout uses STRIPE_PRICE_PREMIUM for subscriptions)
STRIPE_PRICE_FREE=
STRIPE_PRICE_PREMIUM=

# --- Food catalog: Open Food Facts (default — no key; GET /catalog/food/search) ---
# Optional: override wger base URL for Exercise catalog search
# WGER_API_URL=https://wger.de/api/v2

# --- OpenAI (optional; if OPENAI_API_KEY is empty, workout plans use built-in rules) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Email (optional — nodemailer + SMTP; same pattern as MatchFund / Founder–Investor)
# If unset, notification preference toggles still save but no email is sent.
# Gmail: App Password, port 587, SMTP_SECURE=false (STARTTLS).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
# Display name in the "From" header (optional)
EMAIL_FROM_NAME=FitSphere
# Accent color in HTML emails (optional, default #0066ee)
EMAIL_BRAND_ACCENT=#0066ee

# --- Scheduled reminder emails (node-cron; no Redis)
# Set REMINDER_CRONS_ENABLED=false to disable all digest jobs.
# IANA timezone for expressions below (optional; server local time if unset)
# REMINDER_CRON_TIMEZONE=America/New_York
# Standard 5-field cron (minute hour day month weekday). Defaults:
# CRON_WORKOUT_REMINDER=0 9 * * *
# CRON_CHALLENGE_DIGEST=0 10 * * 1
# CRON_WEEKLY_SUMMARY=0 18 * * 0
